{
  "name": "DispatchWaveConfig",
  "type": "object",
  "properties": {
    "gps_waves_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Activer le dispatch GPS par vagues configurables"
    },
    "waves_json": {
      "type": "string",
      "description": "JSON array: [{size: number, timeout_sec: number}, ...] \u2014 size=999 signifie 'tous les restants'"
    }
  },
  "required": [
    "waves_json"
  ]
}
