{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "participants": {
      "type": "string",
      "description": "JSON: [{type: 'client'|'livreur'|'admin', id: string, name: string}] - participants \u00e0 la conversation"
    },
    "last_message": {
      "type": "string",
      "description": "Aper\u00e7u du dernier message"
    },
    "last_message_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date du dernier message"
    },
    "last_sender_name": {
      "type": "string",
      "description": "Nom du dernier exp\u00e9diteur"
    },
    "last_sender_type": {
      "type": "string",
      "enum": [
        "client",
        "livreur",
        "admin",
        "partenaire"
      ],
      "description": "Type du dernier exp\u00e9diteur \u2014 utilis\u00e9 pour le suivi de lecture admin"
    },
    "admin_last_read_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date de la derni\u00e8re fois que l'admin a ouvert cette conversation"
    },
    "title": {
      "type": "string",
      "description": "Titre de la conversation (optionnel, auto-g\u00e9n\u00e9r\u00e9 si absent)"
    },
    "group_type": {
      "type": "string",
      "enum": [
        "direct",
        "group"
      ],
      "default": "direct",
      "description": "Type de conversation"
    }
  },
  "required": [
    "participants"
  ]
}