{
  "name": "Conversation",
  "type": "object",
  "properties": {
    "participants": {
      "type": "string",
      "description": "JSON: [{type: 'client'|'livreur'|'admin'|'partenaire', id: string, name: string}]"
    },
    "last_message": {
      "type": "string"
    },
    "last_message_date": {
      "type": "string",
      "format": "date-time"
    },
    "last_sender_name": {
      "type": "string"
    },
    "last_sender_type": {
      "type": "string",
      "enum": [
        "client",
        "livreur",
        "admin",
        "partenaire"
      ]
    },
    "admin_last_read_date": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string"
    },
    "group_type": {
      "type": "string",
      "enum": [
        "direct",
        "group"
      ],
      "default": "direct"
    },
    "whatsapp_phone": {
      "type": "string",
      "description": "Numero WhatsApp du client (format international sans +)"
    },
    "source": {
      "type": "string",
      "enum": [
        "app",
        "whatsapp"
      ],
      "default": "app",
      "description": "Origine de la conversation"
    },
    "venus_active": {
      "type": "boolean",
      "default": true,
      "description": "True si Venus repond automatiquement, False si un admin a pris la main"
    },
    "assigned_admin_email": {
      "type": "string",
      "description": "Email de l'admin qui a pris la main"
    },
    "ville": {
      "type": "string",
      "description": "Ville du client (si detectee)"
    },
    "country_code": {
      "type": "string",
      "enum": [
        "BF",
        "CI",
        "TG",
        "BJ",
        "SN",
        "ML",
        "GN",
        "NE",
        "GH",
        ""
      ],
      "default": "",
      "description": "Code pays detecte depuis le numero WhatsApp"
    },
    "archived": {
      "type": "boolean",
      "default": false,
      "description": "Conversation archivee par l'admin"
    }
  },
  "required": [
    "participants"
  ]
}