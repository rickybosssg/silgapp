{
  "appId": "com.base6a0ec08f3af5e1d1284254c1.app",
  "appName": "SILGAPP",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "allowNavigation": [
      "silga-dispatch-go.base44.app",
      "*.base44.com",
      "base44.com",
      "*.base44.app",
      "base44.app"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": true
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}
